generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                    Int      @id @default(autoincrement())
  nom                   String
  telephone             String?
  email                 String?
  adresse               String?
  wilaya                String?
  ville                 String?
  nif                   String?
  rc                    String?
  nis                   String?
  cnas_numero           String?
  code_activite         String?
  logo_url              String?
  created_at            DateTime @default(now())
  
  users                 User[]
  chantiers             Chantier[]
  marches               Marche[]
  clients               Client[]
  fournisseurs          Fournisseur[]
  bons_commande         BonCommande[]
  factures              Facture[]
  devis                 Devis[]
  depenses              Depense[]
  comptes_tresorerie    CompteTresorerie[]
  periodes_paie         PeriodePaie[]
  cautions              CautionBancaire[]
  calculs_metier        CalculMetier[]
  prix_marche           PrixMarche[]
  preference_notification PreferenceNotification?
}

model User {
  id                 Int      @id @default(autoincrement())
  company_id         Int
  nom                String
  email              String   @unique
  password_hash      String
  role               String   // SUPER_ADMIN | DIRECTEUR | CHEF_CHANTIER | COMPTABLE | TERRAIN
  telephone          String?
  actif              Boolean  @default(true)
  invitation_token   String?
  invitation_expires DateTime?
  created_at         DateTime @default(now())
  
  company            Company  @relation(fields: [company_id], references: [id])
}

model Chantier {
  id                   Int      @id @default(autoincrement())
  company_id           Int
  nom                  String
  type_chantier        String?  // Construction neuve | Rénovation | Extension | TP
  chef_id              Int?
  wilaya               String?
  adresse              String?
  statut               String   @default("EN_COURS") // EN_COURS | EN_PAUSE | TERMINE | ANNULE
  avancement_physique  Float    @default(0)
  avancement_eco       Float    @default(0)
  budget_prevu         Float    @default(0)
  budget_reel          Float    @default(0)
  date_debut           DateTime?
  date_fin_prevue      DateTime?
  date_fin_reelle      DateTime?
  marche_id            Int?
  workflow_etape       String   @default("PROJET") // PROJET | MARCHE | DQE | AVENANTS | SITUATIONS
  created_at           DateTime @default(now())
  
  company              Company  @relation(fields: [company_id], references: [id])
  marche               Marche?  @relation(fields: [marche_id], references: [id])
  
  situations           SituationTravaux[]
  taches               TachePlanning[]
  journal_entrees      JournalChantier[]
  pointages            PointageTerrain[]
  dqe_items            DQEItem[]
  bons_commande        BonCommande[]
  devis                Devis[]
  factures             Facture[]
  depenses             Depense[]
}

model Marche {
  id                      Int      @id @default(autoincrement())
  company_id              Int
  numero_contrat          String
  titre                   String
  statut                  String   @default("ACTIF") // ACTIF | TERMINE | RESILIE | EN_ATTENTE
  origine                 String   @default("PUBLIC") // PUBLIC | PRIVE | GRE_A_GRE
  maitre_ouvrage_nom      String?
  maitre_ouvrage_adresse  String?
  maitre_ouvrage_tel      String?
  date_contrat            DateTime?
  type_contrat            String?  // Conventionnel | Appel d'offres | Gré à gré
  montant_ht              Float    @default(0)
  tva_taux                Float    @default(19)
  montant_ttc             Float    @default(0)
  delai_initial_jours     Int?
  ods_demarrage           DateTime?
  fin_contractuelle       DateTime?
  retenue_garantie_taux   Float    @default(0)
  rabais_taux             Float    @default(0)
  prix_revisables         Boolean  @default(false)
  avance_forfaitaire      Float    @default(0)
  taux_avance             Float    @default(0)
  avance_appro            Float    @default(0)
  taux_avance_appro       Float    @default(0)
  caution_bonne_exec      Boolean  @default(false)
  mode_plus_values        String   @default("SOUPLE") // STRICT | SOUPLE | LIBRE
  visas_reglementaires    String?  // JSON array
  created_at              DateTime @default(now())
  
  company                 Company  @relation(fields: [company_id], references: [id])
  chantiers               Chantier[]
  lots                    LotMarche[]
  dqe_items               DQEItem[]
  avenants                Avenant[]
}

model LotMarche {
  id          Int      @id @default(autoincrement())
  marche_id   Int
  numero      String
  description String?
  montant_ht  Float    @default(0)
  
  marche      Marche   @relation(fields: [marche_id], references: [id])
}

model DQEItem {
  id            Int      @id @default(autoincrement())
  marche_id     Int?
  chantier_id   Int?
  code_article  String?
  designation   String
  unite         String
  quantite      Float    @default(0)
  prix_unitaire Float    @default(0)
  montant_total Float    @default(0)
  
  marche        Marche?  @relation(fields: [marche_id], references: [id])
  chantier      Chantier? @relation(fields: [chantier_id], references: [id])
}

model Avenant {
  id           Int      @id @default(autoincrement())
  marche_id    Int
  numero       Int
  objet        String
  montant      Float    @default(0)
  statut       String   @default("EN_COURS") // EN_COURS | VALIDE | REFUSE
  date_avenant DateTime?
  
  marche       Marche   @relation(fields: [marche_id], references: [id])
}

model SituationTravaux {
  id              Int      @id @default(autoincrement())
  chantier_id     Int
  numero          Int
  periode_mois    Int
  periode_annee   Int
  montant_periode Float    @default(0)
  montant_cumule  Float    @default(0)
  montant_net     Float    @default(0)
  statut          String   @default("SOUMISE") // SOUMISE | APPROUVEE | PAYEE
  created_at      DateTime @default(now())
  
  chantier        Chantier @relation(fields: [chantier_id], references: [id])
}

model TachePlanning {
  id          Int      @id @default(autoincrement())
  chantier_id Int
  nom         String
  date_debut  DateTime?
  date_fin    DateTime?
  est_jalon   Boolean  @default(false)
  avancement  Float    @default(0)
  couleur     String?
  
  chantier    Chantier @relation(fields: [chantier_id], references: [id])
}

model JournalChantier {
  id          Int      @id @default(autoincrement())
  chantier_id Int
  date_entree DateTime @default(now())
  texte       String
  auteur_id   Int?
  photos      String?  // JSON array d'URLs
  
  chantier    Chantier @relation(fields: [chantier_id], references: [id])
}

model PointageTerrain {
  id              Int      @id @default(autoincrement())
  chantier_id     Int
  employe_nom     String
  date            DateTime
  statut          String   // PRESENT | ABSENT | CONGE
  heures_normales Float    @default(8)
  heures_sup      Float    @default(0)
  
  chantier        Chantier @relation(fields: [chantier_id], references: [id])
}

model Client {
  id           Int      @id @default(autoincrement())
  company_id   Int
  nom          String
  email        String?
  telephone    String?
  adresse      String?
  wilaya       String?
  ville        String?
  type         String   @default("PARTICULIER") // PARTICULIER | ENTREPRISE | ORGANISME_PUBLIC
  actif        Boolean  @default(true)
  created_at   DateTime @default(now())
  
  company      Company  @relation(fields: [company_id], references: [id])
  factures     Facture[]
  devis        Devis[]
}

model Fournisseur {
  id           Int      @id @default(autoincrement())
  company_id   Int
  nom          String
  contact_nom  String?
  email        String?
  telephone    String?
  adresse      String?
  zone         String?
  actif        Boolean  @default(true)
  created_at   DateTime @default(now())
  
  company      Company  @relation(fields: [company_id], references: [id])
  bons_commande BonCommande[]
}

model BonCommande {
  id                    Int      @id @default(autoincrement())
  company_id            Int
  numero                String
  fournisseur_id        Int
  chantier_id           Int?
  statut                String   @default("BROUILLON") // BROUILLON | ENVOYE | PARTIELLEMENT_RECU | RECU | ANNULE
  date_commande         DateTime @default(now())
  date_livraison_prevue DateTime?
  montant_ht            Float    @default(0)
  tva_taux              Float    @default(19)
  montant_ttc           Float    @default(0)
  notes                 String?
  created_at            DateTime @default(now())
  
  company               Company     @relation(fields: [company_id], references: [id])
  fournisseur           Fournisseur @relation(fields: [fournisseur_id], references: [id])
  chantier              Chantier?   @relation(fields: [chantier_id], references: [id])
  
  lignes                LigneBC[]
  bons_livraison        BonLivraison[]
  factures_fournisseur  FactureFournisseur[]
}

model LigneBC {
  id                    Int     @id @default(autoincrement())
  bc_id                 Int
  designation           String
  unite                 String
  quantite_commandee    Float
  quantite_receptionnee Float   @default(0)
  prix_unitaire         Float
  montant_total         Float
  
  bc                    BonCommande @relation(fields: [bc_id], references: [id])
  lignes_bl             LigneBL[]
}

model BonLivraison {
  id             Int      @id @default(autoincrement())
  bc_id          Int
  numero         String
  date_reception DateTime @default(now())
  statut         String   @default("RECU")
  notes          String?
  
  bc             BonCommande @relation(fields: [bc_id], references: [id])
  lignes         LigneBL[]
}

model LigneBL {
  id               Int     @id @default(autoincrement())
  bl_id            Int
  ligne_bc_id      Int
  quantite_livree  Float
  notes            String?
  
  bl               BonLivraison @relation(fields: [bl_id], references: [id])
  ligne_bc         LigneBC      @relation(fields: [ligne_bc_id], references: [id])
}

model FactureFournisseur {
  id           Int      @id @default(autoincrement())
  bc_id        Int
  numero       String
  montant_ht   Float
  tva_taux     Float    @default(19)
  montant_ttc  Float
  statut       String   @default("EN_ATTENTE") // EN_ATTENTE | PAYEE
  date_facture DateTime @default(now())
  
  bc           BonCommande @relation(fields: [bc_id], references: [id])
}

model Devis {
  id            Int      @id @default(autoincrement())
  company_id    Int
  numero        String
  client_id     Int?
  chantier_id   Int?
  statut        String   @default("BROUILLON") // BROUILLON | ENVOYE | ACCEPTE | REJETE
  montant_ht    Float    @default(0)
  tva_taux      Float    @default(19)
  montant_ttc   Float    @default(0)
  date_devis    DateTime @default(now())
  date_validite DateTime?
  notes         String?
  created_at    DateTime @default(now())
  
  company       Company  @relation(fields: [company_id], references: [id])
  client        Client?  @relation(fields: [client_id], references: [id])
  chantier      Chantier? @relation(fields: [chantier_id], references: [id])
  
  lignes        LigneDevis[]
}

model LigneDevis {
  id            Int     @id @default(autoincrement())
  devis_id      Int
  designation   String
  unite         String?
  quantite      Float   @default(1)
  prix_unitaire Float   @default(0)
  montant       Float   @default(0)
  
  devis         Devis   @relation(fields: [devis_id], references: [id])
}

model Facture {
  id            Int      @id @default(autoincrement())
  company_id    Int
  numero        String
  client_id     Int?
  chantier_id   Int?
  statut        String   @default("BROUILLON") // BROUILLON | ENVOYEE | PAYEE | PARTIELLE | EN_RETARD
  montant_ht    Float    @default(0)
  tva_taux      Float    @default(19)
  montant_ttc   Float    @default(0)
  montant_paye  Float    @default(0)
  solde_du      Float    @default(0)
  date_facture  DateTime @default(now())
  date_echeance DateTime?
  notes         String?
  created_at    DateTime @default(now())
  
  company       Company  @relation(fields: [company_id], references: [id])
  client        Client?  @relation(fields: [client_id], references: [id])
  chantier      Chantier? @relation(fields: [chantier_id], references: [id])
  
  lignes        LigneFacture[]
  paiements     Paiement[]
}

model LigneFacture {
  id            Int     @id @default(autoincrement())
  facture_id    Int
  designation   String
  unite         String?
  quantite      Float   @default(1)
  prix_unitaire Float   @default(0)
  montant       Float   @default(0)
  
  facture       Facture @relation(fields: [facture_id], references: [id])
}

model Paiement {
  id            Int      @id @default(autoincrement())
  facture_id    Int
  montant       Float
  date_paiement DateTime @default(now())
  mode          String   // VIREMENT | CHEQUE | ESPECES | TRAITE
  reference     String?
  
  facture       Facture  @relation(fields: [facture_id], references: [id])
}

model Depense {
  id            Int      @id @default(autoincrement())
  company_id    Int
  chantier_id   Int?
  designation   String
  categorie     String   // Matériaux | Matériel | Main-d'oeuvre | Services publics | Autre
  montant       Float
  statut        String   @default("EN_ATTENTE") // EN_ATTENTE | APPROUVE | REJETE
  date_depense  DateTime @default(now())
  notes         String?
  created_at    DateTime @default(now())
  
  company       Company  @relation(fields: [company_id], references: [id])
  chantier      Chantier? @relation(fields: [chantier_id], references: [id])
}

model CompteTresorerie {
  id            Int      @id @default(autoincrement())
  company_id    Int
  nom           String
  type          String   // CAISSE | BANQUE | CCP
  solde         Float    @default(0)
  actif         Boolean  @default(true)
  created_at    DateTime @default(now())
  
  company       Company  @relation(fields: [company_id], references: [id])
  
  transactions  Transaction[]
  cheques       Cheque[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  compte_id   Int
  libelle     String
  montant     Float    // positif = entrée, négatif = sortie
  date        DateTime @default(now())
  statut      String   @default("EN_ATTENTE") // EN_ATTENTE | VALIDE
  reference   String?
  
  compte      CompteTresorerie @relation(fields: [compte_id], references: [id])
}

model Cheque {
  id            Int      @id @default(autoincrement())
  compte_id     Int
  numero        String
  beneficiaire  String
  montant       Float
  date_echeance DateTime
  type          String   // A_RECEVOIR | A_PAYER
  statut        String   @default("EN_ATTENTE") // EN_ATTENTE | ENCAISSE | REJETE
  
  compte        CompteTresorerie @relation(fields: [compte_id], references: [id])
}

model PeriodePaie {
  id           Int      @id @default(autoincrement())
  company_id   Int
  periode      String   // "Mars 2026"
  mois         Int
  annee        Int
  total_brut   Float    @default(0)
  total_cnas   Float    @default(0)
  total_irg    Float    @default(0)
  total_net    Float    @default(0)
  statut       String   @default("BROUILLON") // BROUILLON | VALIDEE
  created_at   DateTime @default(now())
  
  company      Company  @relation(fields: [company_id], references: [id])
  bulletins    BulletinPaie[]
}

model BulletinPaie {
  id              Int     @id @default(autoincrement())
  periode_id      Int
  employe_nom     String
  salaire_base    Float
  heures          Float   @default(0)
  primes          Float   @default(0)
  brut            Float
  cnas           Float   // 35% du brut
  irg            Float   // barème DZ
  net            Float
  
  periode         PeriodePaie @relation(fields: [periode_id], references: [id])
}

model CautionBancaire {
  id            Int      @id @default(autoincrement())
  company_id    Int
  numero        String
  beneficiaire  String
  montant       Float
  date_emission DateTime
  date_echeance DateTime
  statut        String   @default("ACTIVE") // ACTIVE | A_RENOUVELER | LIBEREE | EXPIREE
  banque        String?
  type_caution  String?  // Bonne exécution | Restitution avance | Retenue garantie
  created_at    DateTime @default(now())
  
  company       Company  @relation(fields: [company_id], references: [id])
}

model CalculMetier {
  id            Int      @id @default(autoincrement())
  company_id    Int
  metier        String   // PLOMBERIE | REVETEMENT | PEINTURE | ELECTRICITE | MENUISERIE | GROS_OEUVRE | CLIMATISATION | VRD | FINITIONS
  nom           String
  cout_total    Float    @default(0)
  duree_heures  Float    @default(0)
  created_at    DateTime @default(now())
  
  company       Company  @relation(fields: [company_id], references: [id])
  lignes        LigneCalcul[]
}

model LigneCalcul {
  id            Int     @id @default(autoincrement())
  calcul_id     Int
  code          String
  designation   String
  unite         String
  quantite      Float
  prix_unitaire Float
  montant       Float
  
  calcul        CalculMetier @relation(fields: [calcul_id], references: [id])
}

model PrixMarche {
  id            Int      @id @default(autoincrement())
  company_id    Int
  code_article  String
  designation   String
  unite         String
  prix          Float
  metier        String   // PLOMBERIE | REVETEMENT | etc.
  wilaya        String   @default("National")
  source        String?  // "Prix référence Algérie 2025"
  date_prix     DateTime @default(now())
  
  company       Company  @relation(fields: [company_id], references: [id])
}

model PreferenceNotification {
  id                      Int     @id @default(autoincrement())
  company_id              Int     @unique
  depenses_en_attente     Boolean @default(true)
  factures_en_retard      Boolean @default(true)
  rappels_taches          Boolean @default(true)
  seuil_avertissement     Int     @default(80)  // %
  seuil_critique          Int     @default(100) // %
  delai_rappel_jours      Int     @default(3)
  
  company                 Company @relation(fields: [company_id], references: [id])
}
