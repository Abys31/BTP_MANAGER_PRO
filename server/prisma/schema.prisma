generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// MULTI-TENANCY
model Company {
  id         Int      @id @default(autoincrement())
  nom        String
  rc         String?
  nif        String?
  nis        String?
  art        String?
  adresse    String?
  telephone  String?
  email      String?
  logo_url   String?
  created_at DateTime @default(now())

  users               User[]
  projects            Project[]
  chantiers           Chantier[]
  fournisseurs        Fournisseur[]
  clients             Client[]
  bons_commandes      BonCommande[]
  factures_fournisseurs FactureFournisseur[]
  categories_articles CategorieArticle[]
  articles            Article[]
  mouvements_stock    MouvementStock[]
  inventaires         Inventaire[]
  employes            Employe[]
  pointages           Pointage[]
  bulletins_paie      BulletinPaie[]
  immobilisations     Immobilisation[]
  contrats_vente      ContratVente[]
  depenses_directes   DepenseDirecte[]
  charges_fixes       ChargeFixe[]
  sous_traitants      SousTraitant[]
  contrats_st         ContratSousTraitance[]
  documents           Document[]
  audit_logs          AuditLog[]
}

model User {
  id            Int      @id @default(autoincrement())
  company_id    Int
  nom           String
  prenom        String
  email         String   @unique
  password_hash String
  role          String   @default("READONLY") // SUPER_ADMIN, DIRECTEUR, CONDUCTEUR_TRAVAUX, COMPTABLE, POINTEUR, READONLY
  telephone     String?
  actif         Boolean  @default(true)
  created_at    DateTime @default(now())

  company       Company  @relation(fields: [company_id], references: [id])
  audit_logs    AuditLog[]
}

// PROJETS & CHANTIERS
model Project {
  id              Int      @id @default(autoincrement())
  company_id      Int
  code            String
  nom             String
  type_projet     String   // LOTISSEMENT, PROMOTION_IMMOBILIERE, TRAVAUX_PUBLICS, BATIMENT, RENOVATION
  statut          String   // ETUDE, EN_COURS, SUSPENDU, TERMINE, ANNULE
  date_debut      DateTime
  date_fin_prevue DateTime
  date_fin_reelle DateTime?
  budget_total    Float
  adresse         String?
  wilaya          String?
  commune         String?
  description     String?
  created_by      Int
  created_at      DateTime @default(now())

  company         Company    @relation(fields: [company_id], references: [id])
  chantiers       Chantier[]
  lots            Lot[]
}

model Chantier {
  id              Int      @id @default(autoincrement())
  project_id      Int
  company_id      Int
  code            String
  nom             String
  statut          String   // EN_COURS, TERMINE, etc.
  date_debut      DateTime
  date_fin_prevue DateTime
  budget_alloue   Float
  responsable_id  Int?
  adresse         String?
  superficie      Float?
  description     String?

  company               Company              @relation(fields: [company_id], references: [id])
  project               Project              @relation(fields: [project_id], references: [id])
  bons_commandes      BonCommande[]
  bons_livraison      BonLivraison[]
  mouvements_stock      MouvementStock[]
  affectations_chantier AffectationChantier[]
  pointages             Pointage[]
  affectations_materiel AffectationMateriel[]
  depenses_directes     DepenseDirecte[]
  contrats_st         ContratSousTraitance[]
  budgets               BudgetChantier[]
}

// TIERS
model Fournisseur {
  id              Int      @id @default(autoincrement())
  company_id      Int
  raison_sociale  String
  rc              String?
  nif             String?
  adresse         String?
  wilaya          String?
  telephone       String?
  email           String?
  rib             String?
  banque          String?
  solde_courant   Float    @default(0)
  notes           String?
  actif           Boolean  @default(true)

  company         Company               @relation(fields: [company_id], references: [id])
  bons_commandes  BonCommande[]
  factures        FactureFournisseur[]
}

model Client {
  id             Int      @id @default(autoincrement())
  company_id     Int
  type_client    String   // PARTICULIER, ENTREPRISE
  nom_complet    String
  cin_ou_rc      String?
  adresse        String?
  wilaya         String?
  telephone      String?
  email          String?
  notes          String?
  actif          Boolean  @default(true)

  company        Company        @relation(fields: [company_id], references: [id])
  contrats_vente ContratVente[]
}

// ACHATS & FOURNISSEURS
model BonCommande {
  id                    Int      @id @default(autoincrement())
  company_id            Int
  chantier_id           Int
  fournisseur_id        Int
  numero_bc             String
  date_bc               DateTime
  date_livraison_prevue DateTime?
  statut                String   // BROUILLON, ENVOYE, PARTIELLEMENT_LIVRE, LIVRE, ANNULE
  montant_ht            Float    @default(0)
  tva_taux              Float    @default(19)
  montant_ttc           Float    @default(0)
  notes                 String?
  created_by            Int

  company               Company              @relation(fields: [company_id], references: [id])
  chantier              Chantier             @relation(fields: [chantier_id], references: [id])
  fournisseur           Fournisseur          @relation(fields: [fournisseur_id], references: [id])
  lignes                LigneBC[]
  bons_livraison        BonLivraison[]
  factures              FactureFournisseur[]
}

model LigneBC {
  id                 Int      @id @default(autoincrement())
  bon_commande_id    Int
  article_id         Int
  designation        String
  unite              String
  quantite_commandee Float
  quantite_recue     Float    @default(0)
  prix_unitaire_ht   Float
  montant_ht         Float

  bon_commande       BonCommande @relation(fields: [bon_commande_id], references: [id])
  article            Article     @relation(fields: [article_id], references: [id])
  lignes_bl          LigneBL[]
}

model BonLivraison {
  id                 Int      @id @default(autoincrement())
  bon_commande_id    Int
  chantier_id        Int
  numero_bl          String
  date_reception     DateTime
  statut             String
  notes              String?
  created_by         Int

  bon_commande       BonCommande @relation(fields: [bon_commande_id], references: [id])
  chantier           Chantier   @relation(fields: [chantier_id], references: [id])
  lignes             LigneBL[]
}

model LigneBL {
  id                 Int      @id @default(autoincrement())
  bon_livraison_id   Int
  ligne_bc_id        Int
  quantite_livree    Float
  notes              String?

  bon_livraison      BonLivraison @relation(fields: [bon_livraison_id], references: [id])
  ligne_bc           LigneBC      @relation(fields: [ligne_bc_id], references: [id])
}

model FactureFournisseur {
  id                 Int      @id @default(autoincrement())
  company_id         Int
  fournisseur_id     Int
  bon_commande_id    Int?
  numero_facture     String
  date_facture       DateTime
  date_echeance      DateTime?
  montant_ht         Float
  tva_taux           Float    @default(19)
  montant_tva        Float
  montant_ttc        Float
  statut_paiement    String   // EN_ATTENTE, PARTIELLEMENT_PAYE, PAYE, LITIGE
  notes              String?

  company            Company          @relation(fields: [company_id], references: [id])
  fournisseur        Fournisseur      @relation(fields: [fournisseur_id], references: [id])
  bon_commande       BonCommande?     @relation(fields: [bon_commande_id], references: [id])
  paiements          PaiementFournisseur[]
}

model PaiementFournisseur {
  id                      Int      @id @default(autoincrement())
  facture_fournisseur_id  Int
  date_paiement           DateTime
  montant                 Float
  mode_paiement           String   // ESPECES, VIREMENT, CHEQUE, TRAITE, COMPENSATION
  reference               String?
  notes                   String?

  facture                 FactureFournisseur @relation(fields: [facture_fournisseur_id], references: [id])
}

// STOCKS & MATÉRIAUX
model CategorieArticle {
  id          Int      @id @default(autoincrement())
  company_id  Int
  nom         String
  description String?
  parent_id   Int?

  company     Company   @relation(fields: [company_id], references: [id])
  articles    Article[]
}

model Article {
  id                   Int      @id @default(autoincrement())
  company_id           Int
  categorie_id         Int
  code                 String
  designation          String
  unite                String   // KG, TONNE, ML, M2, M3, PIECE, UNITE, SAC, LITRE, FORFAIT
  prix_unitaire_moyen  Float    @default(0)
  stock_actuel         Float    @default(0)
  stock_minimum        Float    @default(0)
  stock_maximum        Float?
  description          String?
  actif                Boolean  @default(true)

  company              Company           @relation(fields: [company_id], references: [id])
  categorie            CategorieArticle  @relation(fields: [categorie_id], references: [id])
  lignes_bc            LigneBC[]
  mouvements_stock     MouvementStock[]
  lignes_inventaire    LigneInventaire[]
}

model MouvementStock {
  id                 Int      @id @default(autoincrement())
  company_id         Int
  article_id         Int
  chantier_id        Int?
  type_mouvement     String   // ENTREE_ACHAT, ENTREE_RETOUR, SORTIE_CHANTIER, SORTIE_PERTE, INVENTAIRE_POSITIF, INVENTAIRE_NEGATIF, TRANSFERT_ENTRANT, TRANSFERT_SORTANT
  quantite           Float
  prix_unitaire      Float
  valeur_totale      Float
  reference_document String?
  date_mouvement     DateTime @default(now())
  created_by         Int
  notes              String?

  company            Company    @relation(fields: [company_id], references: [id])
  article            Article    @relation(fields: [article_id], references: [id])
  chantier           Chantier?  @relation(fields: [chantier_id], references: [id])
}

model Inventaire {
  id               Int      @id @default(autoincrement())
  company_id       Int
  date_inventaire  DateTime
  statut           String
  notes            String?
  created_by       Int

  company          Company            @relation(fields: [company_id], references: [id])
  lignes           LigneInventaire[]
}

model LigneInventaire {
  id               Int      @id @default(autoincrement())
  inventaire_id    Int
  article_id       Int
  stock_theorique  Float
  stock_physique   Float
  ecart            Float    @default(0)
  valeur_ecart     Float    @default(0)

  inventaire       Inventaire @relation(fields: [inventaire_id], references: [id])
  article          Article    @relation(fields: [article_id], references: [id])
}

// RESSOURCES HUMAINES
model Employe {
  id                   Int      @id @default(autoincrement())
  company_id           Int
  matricule            String
  nom                  String
  prenom               String
  date_naissance       DateTime?
  nin                  String?
  cnas_numero          String?
  qualification        String   // INGENIEUR, TECHNICIEN, CHEF_CHANTIER, OUVRIER_QUALIFIE, OUVRIER, MANOEUVRE, GARDIEN, ADMINISTRATIF
  poste                String?
  type_contrat         String   // CDI, CDD, SAISONNIER, JOURNALIER
  date_embauche        DateTime
  date_fin_contrat     DateTime?
  salaire_base         Float
  prime_chantier       Float    @default(0)
  indemnite_transport  Float    @default(0)
  telephone            String?
  adresse              String?
  rib                  String?
  banque               String?
  actif                Boolean  @default(true)

  company              Company               @relation(fields: [company_id], references: [id])
  affectations         AffectationChantier[]
  pointages            Pointage[]
  bulletins_paie       BulletinPaie[]
  avances              AvanceSalaire[]
  conges               Conge[]
}

model AffectationChantier {
  id                 Int      @id @default(autoincrement())
  employe_id         Int
  chantier_id        Int
  date_debut         DateTime
  date_fin           DateTime?
  poste_sur_chantier String?
  notes              String?

  employe            Employe    @relation(fields: [employe_id], references: [id])
  chantier           Chantier   @relation(fields: [chantier_id], references: [id])
}

model Pointage {
  id                 Int      @id @default(autoincrement())
  company_id         Int
  employe_id         Int
  chantier_id        Int
  date_pointage      DateTime
  heure_entree       String?
  heure_sortie       String?
  heures_normales    Float    @default(8)
  heures_sup_25      Float    @default(0)
  heures_sup_50      Float    @default(0)
  heures_sup_100     Float    @default(0)
  statut_journee     String   // PRESENT, ABSENT, CONGE, MALADIE, FERIE, MISSION
  notes              String?

  company            Company    @relation(fields: [company_id], references: [id])
  employe            Employe    @relation(fields: [employe_id], references: [id])
  chantier           Chantier   @relation(fields: [chantier_id], references: [id])
}

model BulletinPaie {
  id                   Int      @id @default(autoincrement())
  company_id           Int
  employe_id           Int
  mois                 Int
  annee                Int
  jours_travailles     Float
  heures_normales      Float
  heures_sup_25        Float
  heures_sup_50        Float
  salaire_brut         Float
  prime_chantier       Float    @default(0)
  indemnite_transport  Float    @default(0)
  autres_primes        Float    @default(0)
  retenues_cnas        Float    @default(0)
  retenues_irg         Float    @default(0)
  autres_retenues      Float    @default(0)
  avances_deduites     Float    @default(0)
  salaire_net          Float
  statut               String   // BROUILLON, VALIDE, PAYE
  date_paiement        DateTime?
  notes                String?

  company              Company  @relation(fields: [company_id], references: [id])
  employe              Employe  @relation(fields: [employe_id], references: [id])
}

model AvanceSalaire {
  id                 Int      @id @default(autoincrement())
  employe_id         Int
  date_avance        DateTime
  montant            Float
  motif              String?
  remboursement_prevu DateTime?
  statut             String   // EN_ATTENTE, DEDUITE, ANNULEE

  employe            Employe  @relation(fields: [employe_id], references: [id])
}

model Conge {
  id                 Int      @id @default(autoincrement())
  employe_id         Int
  type_conge         String   // ANNUEL, MALADIE, MATERNITE, SANS_SOLDE, AUTRE
  date_debut         DateTime
  date_fin           DateTime
  nombre_jours       Float
  statut             String   // DEMANDE, ACCEPTE, REFUSE
  notes              String?

  employe            Employe  @relation(fields: [employe_id], references: [id])
}

// IMMOBILISATIONS & MATÉRIEL
model Immobilisation {
  id                         Int      @id @default(autoincrement())
  company_id                 Int
  code                       String   @unique
  designation                String
  categorie                  String   // ENGIN_TP, VEHICULE, OUTILLAGE, EQUIPEMENT_BUREAU, MATERIEL_INFORMATIQUE
  marque                     String?
  modele                     String?
  numero_serie               String?
  date_acquisition           DateTime
  valeur_acquisition         Float
  duree_amortissement_ans    Float
  valeur_residuelle          Float    @default(0)
  statut                     String   // EN_SERVICE, EN_MAINTENANCE, HORS_SERVICE, CEDE
  notes                      String?

  company                    Company               @relation(fields: [company_id], references: [id])
  affectations               AffectationMateriel[]
  maintenances               Maintenance[]
}

model AffectationMateriel {
  id                      Int      @id @default(autoincrement())
  immobilisation_id       Int
  chantier_id             Int
  date_affectation        DateTime
  date_retour             DateTime?
  cout_location_journalier Float    @default(0)
  heures_utilisation      Float    @default(0)
  notes                   String?

  immobilisation          Immobilisation @relation(fields: [immobilisation_id], references: [id])
  chantier                Chantier       @relation(fields: [chantier_id], references: [id])
}

model Maintenance {
  id                      Int      @id @default(autoincrement())
  immobilisation_id       Int
  type_maintenance        String   // PREVENTIVE, CORRECTIVE, REVISION
  date_maintenance        DateTime
  cout                    Float
  prestataire             String?
  prochain_entretien_km   Float?
  prochain_entretien_date DateTime?
  description             String?

  immobilisation          Immobilisation @relation(fields: [immobilisation_id], references: [id])
}

// GESTION COMMERCIALE CLIENTS
model Lot {
  id                Int      @id @default(autoincrement())
  project_id        Int
  numero_lot        String
  type_bien         String   // APPARTEMENT, VILLA, LOCAL, TERRAIN
  superficie_terrain Float?
  superficie_batie   Float?
  etage             String?
  prix_vente_ht     Float
  tva_taux          Float    @default(0)
  prix_vente_ttc    Float
  statut            String   // DISPONIBLE, RESERVE, VENDU, LITIGE

  project           Project         @relation(fields: [project_id], references: [id])
  contrats_vente    ContratVente[]
}

model ContratVente {
  id                Int      @id @default(autoincrement())
  company_id        Int
  client_id         Int
  lot_id            Int
  numero_contrat    String
  date_contrat      DateTime
  prix_total_ttc    Float
  montant_apport    Float    @default(0)
  mode_financement  String   // COMPTANT, CREDOC, CREDIT_IMMOBILIER, ECHELONNE
  notaire           String?
  notes             String?
  statut            String   // BROUILLON, SIGNE, ANNULE, SOLDE

  company           Company            @relation(fields: [company_id], references: [id])
  client            Client             @relation(fields: [client_id], references: [id])
  lot               Lot                @relation(fields: [lot_id], references: [id])
  echeances         EcheancePaiement[]
}

model EcheancePaiement {
  id                Int      @id @default(autoincrement())
  contrat_vente_id  Int
  numero_tranche    Int
  date_echeance     DateTime
  montant_appel     Float
  montant_encaisse  Float    @default(0)
  statut            String   // EN_ATTENTE, PARTIELLEMENT_PAYEE, PAYEE, EN_RETARD
  notes             String?

  contrat_vente     ContratVente   @relation(fields: [contrat_vente_id], references: [id])
  encaissements     Encaissement[]
}

model Encaissement {
  id                 Int      @id @default(autoincrement())
  echeance_id        Int
  date_encaissement  DateTime
  montant            Float
  mode_paiement      String   // ESPECES, VIREMENT, CHEQUE
  reference_paiement String?
  notes              String?
  created_by         Int

  echeance           EcheancePaiement @relation(fields: [echeance_id], references: [id])
}

// CHARGES FIXES & DÉPENSES DIRECTES
model DepenseDirecte {
  id               Int      @id @default(autoincrement())
  company_id       Int
  chantier_id      Int
  categorie_depense String  // LOCATION_MATERIEL, SOUS_TRAITANCE, HONORAIRES, ASSURANCE, TRANSPORT, CARBURANT, ELECTRICITE, COMMUNICATION, AUTRE
  description      String
  montant_ht       Float
  tva_taux         Float    @default(19)
  montant_ttc      Float
  date_depense     DateTime
  justificatif_url String?
  statut_paiement  String   // NON_PAYE, PAYE
  created_by       Int

  company          Company   @relation(fields: [company_id], references: [id])
  chantier         Chantier  @relation(fields: [chantier_id], references: [id])
}

model ChargeFixe {
  id               Int      @id @default(autoincrement())
  company_id       Int
  designation      String
  montant_mensuel  Float
  date_debut       DateTime
  date_fin         DateTime?
  actif            Boolean  @default(true)

  company          Company  @relation(fields: [company_id], references: [id])
}

// SOUS-TRAITANCE
model SousTraitant {
  id               Int      @id @default(autoincrement())
  company_id       Int
  raison_sociale   String
  rc               String?
  nif              String?
  specialite       String?
  telephone        String?
  email            String?
  actif            Boolean  @default(true)

  company          Company                @relation(fields: [company_id], references: [id])
  contrats         ContratSousTraitance[]
}

model ContratSousTraitance {
  id               Int      @id @default(autoincrement())
  company_id       Int
  chantier_id      Int
  sous_traitant_id Int
  numero_contrat   String
  objet            String
  montant_ht       Float
  tva_taux         Float    @default(19)
  date_debut       DateTime
  date_fin         DateTime?
  statut           String   // BROUILLON, EN_COURS, TERMINE, ANNULE

  company          Company            @relation(fields: [company_id], references: [id])
  chantier         Chantier           @relation(fields: [chantier_id], references: [id])
  sous_traitant    SousTraitant       @relation(fields: [sous_traitant_id], references: [id])
  situations       SituationTravauxST[]
}

model SituationTravauxST {
  id                       Int      @id @default(autoincrement())
  contrat_st_id            Int
  numero_situation         Int
  date_situation           DateTime
  montant_cumule_ht        Float
  montant_periode_ht       Float
  retenue_garantie_taux    Float    @default(5)
  montant_paye             Float    @default(0)
  statut                   String   // SOUMISE, VALIDEE, PAYEE

  contrat                  ContratSousTraitance @relation(fields: [contrat_st_id], references: [id])
}

// BUDGET & SUIVI FINANCIER
model BudgetChantier {
  id               Int      @id @default(autoincrement())
  chantier_id      Int
  version          Int      @default(1)
  date_budget      DateTime @default(now())
  statut           String   // BROUILLON, VALIDE, REVISE
  notes            String?
  created_by       Int

  chantier         Chantier      @relation(fields: [chantier_id], references: [id])
  lignes           LigneBudget[]
}

model LigneBudget {
  id               Int      @id @default(autoincrement())
  budget_id        Int
  categorie        String   // MATERIAUX, MAIN_OEUVRE, SOUS_TRAITANCE, MATERIEL, FRAIS_GENERAUX
  sous_categorie   String?
  description      String
  montant_prevu    Float
  montant_realise  Float    @default(0)
  notes            String?

  budget           BudgetChantier @relation(fields: [budget_id], references: [id])
}

// DOCUMENTS & PIÈCES JOINTES
model Document {
  id               Int      @id @default(autoincrement())
  company_id       Int
  entity_type      String   // PROJET, CHANTIER, EMPLOYE, FACTURE, etc.
  entity_id        Int
  nom_fichier      String
  chemin_fichier   String
  taille           Int
  mime_type        String
  description      String?
  created_by       Int
  created_at       DateTime @default(now())

  company          Company  @relation(fields: [company_id], references: [id])
}

// AUDIT & LOGS
model AuditLog {
  id               Int      @id @default(autoincrement())
  company_id       Int
  user_id          Int
  action           String   // CREATE, UPDATE, DELETE, LOGIN
  entity_type      String
  entity_id        Int?
  old_values       String?  // JSON string
  new_values       String?  // JSON string
  ip_address       String?
  user_agent       String?
  created_at       DateTime @default(now())

  company          Company  @relation(fields: [company_id], references: [id])
  user             User     @relation(fields: [user_id], references: [id])
}
